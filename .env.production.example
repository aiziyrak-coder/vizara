# Vizara production — API server (api.vizara.uz)
NODE_ENV=production
PORT=3011
HOST=127.0.0.1

DATABASE_URL="file:/var/www/vizara/data/vizara.db"

# Generate on server: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="CHANGE_ON_SERVER"

APP_URL="https://vizara.uz"
CORS_ORIGIN="https://vizara.uz"

DEMO_MODE="true"
ALLOW_DEMO_IN_PRODUCTION="true"

TRUST_PROXY_HOPS=1
MAX_UPLOAD_SIZE_MB=4096

# OpenAI — set only on server, never in git
# OPENAI_API_KEY=""
# AI_MODEL="gpt-4o"
