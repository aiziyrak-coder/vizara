{
  "name": "vizara",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --port=3000 --host=0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "build:server": "node scripts/build-server.mjs",
    "build:all": "npm run build:prod && npm run build:server",
    "verify": "node scripts/verify.mjs",
    "prestart": "node -e \"const fs=require('fs'); if(!fs.existsSync('dist-server/index.js')){console.error('Run: npm run build:all'); process.exit(1)}\"",
    "preview": "vite preview",
    "start": "node dist-server/index.js",
    "start:dev": "tsx server/index.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json",
    "clean": "node -e \"const fs=require('fs');['dist','dist-server','uploads'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true})}catch(e){}})\""
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^1.4.5-lts.2",
    "openai": "^6.44.0",
    "pannellum": "^2.5.6",
    "prisma": "^6.8.2",
    "qrcode": "^1.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.6.2",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.5",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
