# ─── Database ───
DATABASE_URL="file:./dev.db"

# ─── Auth (production: min 32 char random hex) ───
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="vizara-change-this-secret-in-production"

# ─── Public URL ───
APP_URL="http://localhost:3000"

# CORS (comma-separated; defaults to APP_URL)
# CORS_ORIGIN="http://localhost:3000,https://vizara.example.com"

# ─── Demo (development only; blocked in production) ───
DEMO_MODE="true"
# ALLOW_DEMO_IN_PRODUCTION="true"  # emergency override — NOT recommended

# ─── Stripe (required in production when DEMO_MODE=false) ───
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_BUSINESS=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_ENTERPRISE=""

# ─── Server ───
NODE_ENV="development"
PORT=3001
HOST=0.0.0.0
TRUST_PROXY_HOPS=1

# Max single model upload in MB (default 4096 = 4 GB). Tarif bo'yicha limit yo'q.
# MAX_UPLOAD_SIZE_MB=4096

# Docker production override:
# DATABASE_URL="file:/app/data/dev.db"
